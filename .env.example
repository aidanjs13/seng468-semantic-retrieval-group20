# JWT secret
JWT_SECRET=example-secret
JWT_EXPIRES_IN_HOURS=24

# Postgres database
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=semantic_retrieval

# Minio creds
MINIO_ROOT_USER=minioexample
MINIO_ROOT_PASSWORD=minioexamplepass
MINIO_ENDPOINT=minio:9000

# Database connection used by the Flask app
DATABASE_URL=postgresql://app:app@db:5432/semantic_retrieval

REDIS_URL=redis://redis:6379/0
